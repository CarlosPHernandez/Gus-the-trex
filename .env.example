# Copy to .env and fill in after creating a Supabase project + running the migration in supabase/migrations/

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-only: for npm run add-pledge + Resend email verification (never expose in the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Resend — coalition welcome + pledge confirmation emails (Vercel /api only)
# https://resend.com/api-keys · verify your sending domain first
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Gus Campaign <campaign@yourdomain.com>
# Public site URL for email links (optional; Vercel sets VERCEL_URL automatically)
CAMPAIGN_SITE_URL=https://your-production-domain.com
