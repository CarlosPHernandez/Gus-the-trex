# Copy to .env and fill in after creating a Supabase project + running the migration in supabase/migrations/

PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Server-only: for npm run add-pledge (never commit or expose in the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
