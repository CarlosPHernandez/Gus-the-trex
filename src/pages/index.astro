---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import HeroSlider from "../components/HeroSlider.astro";
import PledgeModule from "../components/PledgeModule.astro";
import TierGrid from "../components/TierGrid.astro";
import Dossier from "../components/Dossier.astro";
import MapSection from "../components/MapSection.astro";
import HowItWorks from "../components/HowItWorks.astro";
import CoalitionSignup from "../components/CoalitionSignup.astro";
import FaqSection from "../components/FaqSection.astro";
import PledgeModal from "../components/PledgeModal.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main>
    <section class="hero container">
      <div class="hero__slider">
        <HeroSlider />
      </div>
      <div class="hero__pledge">
        <PledgeModule />
      </div>
    </section>
    <HowItWorks />
    <CoalitionSignup />
    <TierGrid />
    <FaqSection />
    <Dossier />
    <MapSection />
  </main>
  <Footer />
  <PledgeModal />
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 2rem;
    padding: 2rem 0 1rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero__pledge {
      order: -1;
    }
  }
</style>
