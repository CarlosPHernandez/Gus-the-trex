---
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Gus — A T. rex for public stewardship",
  description =
    "Help keep Gus—a remarkably complete Tyrannosaurus rex—in public trust. Campaign for museum stewardship ahead of the July 2026 auction.",
} = Astro.props;

const site = Astro.site ?? Astro.url;
const pageUrl = new URL(Astro.url.pathname, site).href;
const ogImagePath = "/images/og-image.jpg";
const ogImage = new URL(ogImagePath, site).href;
const ogImageWidth = 1200;
const ogImageHeight = 630;
const ogImageAlt =
  "Gus the T. rex — fossil skeleton mounted in profile, public stewardship campaign";
const favicon = new URL("/favicon.svg", site).href;
const siteName = "Gus — public stewardship campaign";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:url" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href={favicon} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Source+Sans+3:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
  @import "../styles/mobile.css";
</style>
