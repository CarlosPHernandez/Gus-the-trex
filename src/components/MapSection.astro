---
---

<section class="map-section" id="find-site" aria-labelledby="map-heading">
  <div class="container">
    <h2 id="map-heading" class="display map-section__title">Where Gus was found</h2>
    <p class="map-section__text">
      Western South Dakota — private ranchland where Gary "Gus" Licking and Theropoda Expeditions documented a complex Late Cretaceous fossil bed.
    </p>
    <figure class="map-section__figure card">
      <svg
        viewBox="0 0 560 320"
        role="img"
        aria-label="Map of western South Dakota with find site marked"
        class="map-section__svg"
      >
        <rect width="560" height="320" fill="#e8e2d6" />
        <path
          d="M40 40 H520 V280 H40 Z"
          fill="#f5f3ee"
          stroke="#8b6f56"
          stroke-width="1"
        />
        <path
          d="M80 120 Q200 80 320 100 T480 140 L500 200 Q420 240 300 230 T120 210 Z"
          fill="#2d3a2e"
          opacity="0.12"
        />
        <circle cx="248" cy="168" r="28" fill="none" stroke="#2d3a2e" stroke-width="2" />
        <circle cx="248" cy="168" r="6" fill="#2d3a2e" />
        <text x="248" y="215" text-anchor="middle" font-family="Source Sans 3, sans-serif" font-size="13" fill="#1c1916">Western South Dakota</text>
        <text x="248" y="234" text-anchor="middle" font-family="Source Sans 3, sans-serif" font-size="11" fill="#8b6f56">Discovered 2021 · ranchland</text>
      </svg>
      <figcaption>Illustrative map — not survey coordinates.</figcaption>
    </figure>
  </div>
</section>

<style>
  .map-section {
    padding: 3rem 0;
  }

  .map-section__title {
    margin: 0 0 0.5rem;
    font-size: 1.5rem;
  }

  .map-section__text {
    margin: 0 0 1.25rem;
    max-width: 42ch;
    color: var(--clay);
  }

  .map-section__figure {
    margin: 0;
    padding: 1rem;
  }

  .map-section__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .map-section__figure figcaption {
    margin-top: 0.65rem;
    font-size: 0.78rem;
    color: var(--clay);
  }
</style>
